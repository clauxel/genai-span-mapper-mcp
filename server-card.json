      "inputSchema": {
        "type": "object",
        "properties": {
          "sample": {
            "type": "string",
            "description": "Workflow sample, schema, policy fixture, or agent output."
          },
          "context": {
            "type": "string",
            "description": "Optional review context."
          }
        },
        "required": [
          "sample"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "verdict": {
            "type": "string"
          },
